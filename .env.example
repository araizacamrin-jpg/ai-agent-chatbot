# ── Claude API ──────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com → API Keys → Create Key
CLAUDE_API_KEY=sk-ant-your-key-here

# ── App settings ─────────────────────────────────────────────────────────────
# Set to "production" on Railway, "development" locally (enables auto-reload)
ENVIRONMENT=development

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# ── Server port ──────────────────────────────────────────────────────────────
# Railway injects $PORT automatically — only set this locally if needed
# PORT=8000
